# ---- Python ----
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/
build/
dist/

# Virtual environments
.venv/
venv/
env/

# ---- Node / web ----
web/node_modules/
web/dist/
web/.vite/
*.local
*.tsbuildinfo

# ---- OS / editor ----
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
# Local Claude Code agent worktrees + machine-specific config, except shared
# committed skills (e.g. the fixtures-update routine) used by scheduled agents.
.claude/*
!.claude/skills/

# Spurious root-level npm lockfile (there is no root package.json; the only
# Node project is web/). Prevents an accidental `npm install` at the repo root
# from committing an empty/misleading lockfile.
/package-lock.json

# ---- Local-only docs (kept out of the published repo) ----
ARTICLE.md
worldcup-2026-predictor-SPEC.md

# ---- Project artifacts ----
# Generated reliability plots (regenerated by evaluate.py).
model/evaluation/plots/*.png
# Local experiment scratch (the committed ledger.csv is tracked explicitly).
experiments/scratch/

# NOTE: data/results.csv, model/params.json, and web/public/predictions.json
# are intentionally COMMITTED so a clean clone reproduces published numbers
# (§6.7). They are NOT ignored.
